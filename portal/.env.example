# ─────────────────────────────────────────────
# HorusEye Portal — Environment Variables
# Copy this file to .env.local and fill in values
# ─────────────────────────────────────────────

# Environment: local | staging | production
NEXT_PUBLIC_ENV=local

# Supabase (get from Supabase dashboard > Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# Service role key — SERVER-SIDE ONLY, never expose to client
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Sentry (optional, errors and performance monitoring)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Feature flags
NEXT_PUBLIC_CAMERA_MODULE_ENABLED=false

# AI service (PRD-013) — Phase A: FastAPI camera/AI service
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_WS_URL=ws://localhost:8000
NEXT_PUBLIC_AI_SERVICE_WS_URL=ws://localhost:8000
AI_SERVICE_API_KEY=<generate-a-random-32-char-secret>

# Camera pairing (PRD-019) — HMAC secret for 5-minute pair JWTs
# Generate with: openssl rand -hex 32
PAIR_TOKEN_SECRET=<generate-a-random-32-char-secret>

# Public app URL — used in email templates for logo image and links
NEXT_PUBLIC_APP_URL=http://localhost:3000

# SMTP — 32+ character random string for AES-256-GCM password encryption
# Generate with: openssl rand -hex 32
SMTP_ENCRYPTION_KEY=<generate-a-random-32-char-secret>

# Playwright E2E — override base URL if app runs on different port
# PLAYWRIGHT_BASE_URL=http://localhost:3000
