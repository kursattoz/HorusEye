# ─────────────────────────────────────────────
# HorusEye AI service — Training-time environment
# Copy to .env BEFORE running scripts/train_v1.sh.
# Runtime ai-service uses different env vars (see Dockerfile + CDK).
# ─────────────────────────────────────────────

# ── Dataset sources ─────────────────────────────────────────
# Roboflow Universe API key. 1Password → "Roboflow Universe — HorusEye CI".
ROBOFLOW_API_KEY=

# HuggingFace token (optional). Only needed if MaskedFace-Net / WIDER FACE
# rate-limit anonymous pulls during BL-320 fetch.
HF_TOKEN=

# FiftyOne reuses ~/.fiftyone/config.json but accepts overrides too.
# Leave blank unless you want a non-default scratch dir.
FIFTYONE_DATABASE_URI=

# ── Supabase service-role (for ai_models registry + bucket upload) ──
# Production key — pulled from SSM at deploy time normally. For local
# training set this from `aws ssm get-parameter --name /horuseye/staging/SUPABASE_SERVICE_ROLE_KEY`.
SUPABASE_URL=https://lvannuajbkrbwamzussh.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ── Training knobs (optional — overrides script defaults) ───────────
SPRINT15_EPOCHS=50
SPRINT15_BATCH=16
SPRINT15_DEVICE=cuda:0      # use 'cpu' on a Mac, 'mps' on Apple Silicon, 'cuda:0' on Linux GPU
SPRINT15_PATIENCE=10
SPRINT15_REGISTER=0          # flip to 1 after the A/B passes
SPRINT15_ACTIVATE=0          # flip to 1 after the A/B sign-off (see BL-284)

# Same surface for v2.0:
SPRINT16_EPOCHS=30
SPRINT16_BATCH=16
SPRINT16_DEVICE=cuda:0
STARTING_WEIGHTS=runs/sprint15_v1/weights/best.pt
SPRINT16_REGISTER=0
SPRINT16_ACTIVATE=0
